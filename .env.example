# xAPI LRS Connection (optional — demo mode works without this)
LRS_ENDPOINT=https://lrs.example.com/xapi/
LRS_USERNAME=
LRS_PASSWORD=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Data mode: "demo" loads built-in sample data on startup
DATA_MODE=demo
